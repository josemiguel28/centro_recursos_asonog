# ─── URL Rewriting ────────────────────────────────────────────────────────────
# Redirige todas las peticiones (excepto archivos/carpetas existentes) a index.php
Options -Indexes
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Si la petición corresponde a un archivo real, no reescribir
    RewriteCond %{REQUEST_FILENAME} !-f
    # Si la petición corresponde a un directorio real, no reescribir
    RewriteCond %{REQUEST_FILENAME} !-d
    # En cualquier otro caso reescribir a index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ─── PHP — Subida de archivos ──────────────────────────────────────────────────
# Ajusta los límites de subida para PDFs grandes.
# Muchos hostings comparten permiten sobrescribir estos valores desde .htaccess.
# Si no funciona, tendrás que ajustarlos desde el panel de control (cPanel → PHP Selector).
<IfModule mod_php.c>
    php_value upload_max_filesize 100M
    php_value post_max_size       110M
    php_value memory_limit        256M
    php_value max_execution_time  300
    php_value max_input_time      300
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 100M
    php_value post_max_size       110M
    php_value memory_limit        256M
    php_value max_execution_time  300
    php_value max_input_time      300
</IfModule>

# ─── Seguridad básica ─────────────────────────────────────────────────────────
# Evitar acceso directo a archivos sensibles
<FilesMatch "\.(env|log|sql|json|lock|md)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
